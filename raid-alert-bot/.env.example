# Your personal KAOS+ raid key (from /raidlink in-game or the KAOS+ app)
RAID_KEY=

# KAOS+ app's shared API key (seen as X-Api-Key when the app talks to its backend)
KAOS_API_KEY=

# Discord webhook URL for the channel you want raid alerts posted in
# (Channel Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL)
DISCORD_WEBHOOK_URL=

# Who gets pinged: the literal word "everyone", or a Discord role ID to ping
# that role instead. Right-click a role in Discord (Developer Mode on) and
# "Copy Role ID" to get the ID.
PING_TARGET=everyone

# Optional: only needed if you want credentials to survive a Koyeb redeploy
# (see README). Leave blank on first run -- the app will log a value you can
# copy in here for next time.
CREDENTIALS_JSON=

# Provided automatically by Koyeb/Replit -- do not set manually in production
PORT=8787
