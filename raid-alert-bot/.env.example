# Your personal KAOS+ raid key (from /raidlink in-game or the KAOS+ app)
RAID_KEY=

# KAOS+ app's shared API key (seen as X-Api-Key when the app talks to its backend)
KAOS_API_KEY=

# Discord webhook URL for the channel you want raid alerts posted in
# (Channel Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL)
DISCORD_WEBHOOK_URL=

# Who gets pinged: the literal word "everyone", or a Discord role ID to ping
# that role instead. Right-click a role in Discord (Developer Mode on) and
# "Copy Role ID" to get the ID.
PING_TARGET=everyone

# Optional: only needed if you want credentials to survive a Koyeb redeploy
# (see README). Leave blank on first run -- the app will log a value you can
# copy in here for next time.
CREDENTIALS_JSON=

# --- Twilio phone-call alerts (optional but recommended) ---
# When set, the bot places a real phone call to every number in
# TWILIO_CALL_NUMBERS each time a raid fires -- works on iPhone and Android
# even with the screen off. Leave all four blank to disable.
#
# Get your Account SID and Auth Token from https://console.twilio.com
# (Account Info box on the dashboard home page).
# TWILIO_FROM_NUMBER must be an active Twilio number you own (E.164 format).
# TWILIO_CALL_NUMBERS is a comma-separated list of numbers to call (E.164).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+12015551234
TWILIO_CALL_NUMBERS=+447911123456,+14155551234

# Optional: what the robot voice says on the call.
# Default: "Raid alert! Your base is under attack. Check Discord now."
TWILIO_CALL_MESSAGE=

# Provided automatically by Koyeb/Replit -- do not set manually in production
PORT=8787
