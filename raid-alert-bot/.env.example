# Your personal KAOS+ raid key (from /raidlink in-game or the KAOS+ app)
RAID_KEY=

# KAOS+ app's shared API key (seen as X-Api-Key when the app talks to its backend)
KAOS_API_KEY=

# Discord webhook URL for the channel you want raid alerts posted in
# (Channel Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL)
DISCORD_WEBHOOK_URL=

# Who gets pinged: the literal word "everyone", or a Discord role ID to ping
# that role instead. Right-click a role in Discord (Developer Mode on) and
# "Copy Role ID" to get the ID.
PING_TARGET=everyone

# Optional: only needed if you want credentials to survive a Koyeb redeploy
# (see README). Leave blank on first run -- the app will log a value you can
# copy in here for next time.
CREDENTIALS_JSON=

# Provided automatically by Koyeb/Replit -- do not set manually in production
PORT=8787

# ── Clan registry (enables the Android app's live clan picker) ─────────────────
#
# The MAIN AVIV bot is the registry. Other clan bots register with it on startup.
# The Android app fetches GET /api/clans from the AVIV bot to show the clan list.
#
# ── On the AVIV bot (the registry host): ──────────────────────────────────────
#
# This bot's own publicly accessible Koyeb URL (no trailing slash).
# Required for self-registration. Leave blank to skip.
CLAN_PUBLIC_URL=https://your-aviv-bot.koyeb.app

# Unique lowercase slug for this clan (e.g. "aviv")
CLAN_ID=aviv

# Brand hex colour shown in the Android app clan picker
CLAN_COLOR=#e8430a

# A secret key that all clan bots must send to register themselves.
# Pick any strong random string — must match on every bot that wants to register.
CLAN_REGISTRY_KEY=changeme

# Leave CLAN_REGISTRY_URL blank on the AVIV bot (it IS the registry)
# CLAN_REGISTRY_URL=

# ── On each additional clan bot (e.g. TCK, NOVA, etc.): ──────────────────────
#
# CLAN_ID=tck
# CLAN_COLOR=#3498db
# CLAN_PUBLIC_URL=https://your-tck-bot.koyeb.app
# CLAN_REGISTRY_URL=https://your-aviv-bot.koyeb.app   ← point at the AVIV bot
# CLAN_REGISTRY_KEY=changeme                           ← must match AVIV bot's key
