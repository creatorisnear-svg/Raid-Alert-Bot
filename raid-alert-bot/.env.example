# Your personal KAOS+ raid key (from /raidlink in-game or the KAOS+ app)
RAID_KEY=

# KAOS+ app's shared API key (seen as X-Api-Key when the app talks to its backend)
KAOS_API_KEY=

# Discord webhook URL for the channel you want raid alerts posted in
# (Channel Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL)
DISCORD_WEBHOOK_URL=

# Who gets pinged: the literal word "everyone", or a Discord role ID to ping
# that role instead. Right-click a role in Discord (Developer Mode on) and
# "Copy Role ID" to get the ID.
PING_TARGET=everyone

# Optional: only needed if you want credentials to survive a Koyeb redeploy
# (see README). Leave blank on first run -- the app will log a value you can
# copy in here for next time.
CREDENTIALS_JSON=

# --- ntfy.sh push notifications (free, optional but recommended) ---
# ntfy is a free push notification service (ntfy.sh). Install the ntfy app on
# every clan member's phone, subscribe to the same topic, and they will get a
# loud high-priority notification the instant a raid fires -- even screen-off.
# Android: bypasses Do Not Disturb. iPhone: sounds unless mute switch is on.
#
# Setup:
#   1. Pick a unique topic name -- keep it secret, treat it like a password.
#      Something like "tck-raids-xk29qf" works. No account needed.
#   2. Install the ntfy app: https://ntfy.sh/app
#   3. In the app tap + and enter your topic name.
#   4. Set NTFY_TOPIC below and deploy. Done.
NTFY_TOPIC=

# Optional: use your own self-hosted ntfy server instead of ntfy.sh
NTFY_SERVER=

# Provided automatically by Koyeb/Replit -- do not set manually in production
PORT=8787
