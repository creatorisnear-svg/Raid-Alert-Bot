# Required: the public URL of your raid-alert-bot on Koyeb.
# Example: https://my-bot.koyeb.app
# The app POSTs to /api/subscribe-native and /api/unsubscribe-native here.
EXPO_PUBLIC_BOT_URL=https://your-bot.koyeb.app

# Required for production APK builds -- your Expo project ID from expo.dev.
# Steps:
#   1. Create a free account at https://expo.dev
#   2. Create a new project (or link this one with `eas init`)
#   3. Copy the project ID shown in the project dashboard
#   4. Paste it in app.json under expo.extra.eas.projectId
# Leave this blank when testing in Expo Go -- it works without it.
EXPO_PUBLIC_EAS_PROJECT_ID=
