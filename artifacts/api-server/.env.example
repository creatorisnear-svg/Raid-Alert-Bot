# --- Koyeb deployment env vars for the combined api-server + website service ---
# This one Koyeb service serves BOTH the API and the aviv-clan-plus website
# (Express serves the built frontend + handles SPA routing when STATIC_DIR
# is set — see the Dockerfile). Copy these into Koyeb's dashboard as
# runtime environment variables. (PORT and STATIC_DIR are set automatically
# by Koyeb/the Dockerfile — do not set them manually.)

# Postgres connection string. Replit's built-in dev database ("helium" host)
# is only reachable from inside the Replit workspace — it will NOT work from
# Koyeb. Provision a Postgres Koyeb can reach (Koyeb's own Postgres add-on,
# Neon, Supabase, etc.) and put its connection string here. Then push the
# schema to it once with:
#   DATABASE_URL="<that url>" pnpm --filter @workspace/db run push
DATABASE_URL=

# Long random secret used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=

# Discord OAuth app (create at https://discord.com/developers/applications):
#   - DISCORD_CLIENT_ID / DISCORD_CLIENT_SECRET: from the app's OAuth2 page.
#   - Add a redirect URL there matching: <APP_URL>/api/auth/discord/callback
#   - DISCORD_BOT_TOKEN: from the app's Bot page (needed to read guild
#     channels/roles and post alert messages).
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=

# Public base URL of this service once deployed on Koyeb
# (e.g. https://aviv-clan-plus.koyeb.app) — same URL serves the website too.
# Used to build the Discord OAuth redirect URI and post-login redirects.
APP_URL=
