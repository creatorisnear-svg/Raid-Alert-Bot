# --- Koyeb deployment env vars for aviv-clan-plus (frontend) ---
# These are BUILD-TIME vars (Vite inlines them into the static bundle at
# build time) — in Koyeb, set them as "Build-time" environment variables /
# Docker build ARGs, not runtime env vars.

# Standalone deploy is not path-routed like on Replit, so this must be "/".
BASE_PATH=/

# Public URL of the api-server service once deployed on Koyeb
# (e.g. https://aviv-clan-api.koyeb.app) — no trailing slash, no "/api" suffix.
VITE_API_URL=
